# ══════════════════════════════════════════════════════════════════════════════
# Tomo Backend — Environment Variables
# Copy to .env.local in Vercel → Settings → Environment Variables
# ══════════════════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────────────────
# MongoDB Atlas → Connect → Drivers → copy URI
MONGODB_URI=mongodb+srv://tinga:YOUR_PASSWORD@cluster0.i7rmjyu.mongodb.net/tomo?retryWrites=true&w=majority&appName=Cluster0

# ── JWT (generate: openssl rand -base64 48) ───────────────────────────────────
JWT_SECRET=replace-with-long-random-secret

# ── Superadmin (cannot sign up — login only) ──────────────────────────────────
OWNER_EMAIL=hempstonetinga@gmail.com

# ── Email via Resend (free 3,000/month) ───────────────────────────────────────
# resend.com → API Keys → Create API Key
RESEND_API_KEY=re_xxxx

# ── Google OAuth ──────────────────────────────────────────────────────────────
# 1. Go to console.cloud.google.com
# 2. Create project → APIs & Services → Enable "Google Identity" API
# 3. Credentials → Create OAuth 2.0 Client ID → Web application
# 4. Authorized origins: https://your-app.vercel.app
# 5. Authorized redirect URIs: https://your-app.vercel.app
# 6. Copy the Client ID below AND to Vercel as VITE_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# ── Flutterwave (card payments — Visa/Mastercard) ─────────────────────────────
# dashboard.flutterwave.com → Settings → API Keys
# Works in Kenya — 3.8% per transaction
FLW_PUBLIC_KEY=FLWPUBK-xxxx
FLW_SECRET_KEY=FLWSECK-xxxx
# Webhooks → Set webhook URL: https://your-app.vercel.app/api/payments/card/webhook
# Copy the secret hash below
FLW_WEBHOOK_HASH=your-flutterwave-webhook-hash

# ── M-Pesa via IntaSend ───────────────────────────────────────────────────────
# intasend.com → Create free account → API Keys
# Test mode: use sandbox.intasend.com (no real money)
# Live mode:  use payment.intasend.com
INTASEND_API_KEY=ISSecretKey_live_xxxx
INTASEND_PUBLIC_KEY=ISPubKey_live_xxxx

# ── App ───────────────────────────────────────────────────────────────────────
PORT=4000
FRONTEND_URL=https://your-app.vercel.app
BACKEND_URL=https://your-app.vercel.app
NODE_ENV=production
