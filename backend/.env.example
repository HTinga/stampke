# ── Tomo Backend — Environment Variables ─────────────────────────────────────
# Copy this file to .env and fill in all values before running the server.

# ── Database ─────────────────────────────────────────────────────────────────
# MongoDB Atlas free cluster → Connect → Drivers → copy URI
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/tomo?retryWrites=true&w=majority

# ── JWT ──────────────────────────────────────────────────────────────────────
# Any long random string — generate with: openssl rand -base64 32
JWT_SECRET=replace-with-a-long-random-secret-string

# ── Platform owner ───────────────────────────────────────────────────────────
# This email auto-activates as 'owner' on first signup/Google login
OWNER_EMAIL=hempstonetinga@gmail.com
# Password for owner account created by `npm run setup`
OWNER_PASSWORD=change-this-before-deploying

# ── Google OAuth ─────────────────────────────────────────────────────────────
# console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# ── Email (Resend) ───────────────────────────────────────────────────────────
# resend.com → API Keys (free 3,000 emails/month)
RESEND_API_KEY=re_your_resend_api_key

# ── App ──────────────────────────────────────────────────────────────────────
PORT=4000
# Your deployed Vercel frontend URL (for CORS and email links)
FRONTEND_URL=https://your-app.vercel.app

NODE_ENV=development
