# ══════════════════════════════════════════════════════════════════════════════
# Tomo Backend — Environment Variables
# Copy to .env and fill in all values
# ══════════════════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────────────────
# MongoDB Atlas free M0 → Connect → Drivers → copy URI
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/tomo?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 48
JWT_SECRET=replace-with-a-long-random-secret

# ── Platform superadmin ───────────────────────────────────────────────────────
# This email auto-activates as superadmin on first signup
OWNER_EMAIL=hempstonetinga@gmail.com

# ── Email (Resend) ────────────────────────────────────────────────────────────
# resend.com → API Keys → Create  (free 3,000/month)
RESEND_API_KEY=re_your_resend_key

# ── Google OAuth ──────────────────────────────────────────────────────────────
# console.cloud.google.com → Credentials → OAuth 2.0 Client
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# ── Stripe Payments ───────────────────────────────────────────────────────────
# dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_...
# dashboard.stripe.com → Webhooks → Add endpoint → copy signing secret
# Endpoint URL: https://your-app.vercel.app/api/payments/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_...
# dashboard.stripe.com → Products → create Pro & Enterprise → copy price IDs
STRIPE_PRO_PRICE_ID=price_...
STRIPE_ENTERPRISE_PRICE_ID=price_...

# ── M-Pesa (IntaSend) ─────────────────────────────────────────────────────────
# intasend.com → Create account → API Keys
# Sandbox:  https://sandbox.intasend.com  (use test numbers)
# Live:     https://payment.intasend.com
INTASEND_API_KEY=ISSecretKey_...
INTASEND_PUBLIC_KEY=ISPubKey_...

# ── Upstash Redis (rate limiting / caching) ───────────────────────────────────
# console.upstash.com → Create database → REST API
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# ── App ───────────────────────────────────────────────────────────────────────
PORT=4000
# Your deployed frontend URL (for CORS + email links + Stripe redirects)
FRONTEND_URL=https://your-app.vercel.app
BACKEND_URL=https://your-app.vercel.app
NODE_ENV=development
